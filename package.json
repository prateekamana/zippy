{
  "name": "minimal-vite",
  "version": "0.0.2",
  "description": "",
  "main": "electron-main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite\"",
    "rbdev": "concurrently \"ruby server.rb\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "ELECTRON_ENV=development concurrently \"vite\" \"electronmon .\"",
    "electron:start": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --mac"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.4",
    "vite": "^8.0.1"
  },
  "electronmon": {
    "patterns": [
      "electron-main.js",
      "server.js",
      "db.js"
    ]
  },
  "build": {
    "appId": "com.zippy.tasks",
    "productName": "Tasks",
    "asar": false,
    "files": [
      "dist/**/*",
      "electron-main.js",
      "preload.mjs",
      "server.js",
      "db.js"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": {
        "target": "dmg",
        "arch": [
          "arm64",
          "x64"
        ]
      }
    },
    "directories": {
      "output": "release"
    }
  }
}
